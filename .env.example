# ============================================================
# TORAJA TOURISM RAG - Environment Configuration
# ============================================================

# --- Database ---
DB_HOST=mysql-29b15cf0-vjesflinto.e.aivencloud.com
DB_PORT=26682
DB_NAME=defaultdb
DB_USER=avnadmin
DB_PASSWORD=AVNS_uKg_zo386WTpsOgIaUY

# --- LLM via OpenRouter ---
# Daftar & dapatkan API key di: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Base URL OpenRouter — jangan diubah
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Format model OpenRouter: "provider/model-name"
# Model aktif: openai/gpt-oss-120b
# Contoh lain: "meta-llama/llama-3.3-70b-instruct", "google/gemini-pro"
LLM_MODEL=openai/gpt-oss-120b
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
# Opsional — muncul di dashboard OpenRouter Anda
OPENROUTER_SITE_URL=http://localhost:8501
OPENROUTER_APP_NAME=Toraja Tourism RAG

# --- Embedding ---
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384

# --- FAISS ---
FAISS_INDEX_PATH=./data/faiss_index
FAISS_K=5

# --- App ---
APP_SECRET_KEY=your_secret_key_here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
APP_DEBUG=False

# --- MMR ---
MMR_ENABLED=true    # aktif/matikan
MMR_LAMBDA=0.5      # 0.0–1.0
MMR_FETCH_K=20      # ukuran candidate pool